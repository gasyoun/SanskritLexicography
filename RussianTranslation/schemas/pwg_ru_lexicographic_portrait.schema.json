{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pwg_ru.lexicographic_portrait.schema.v1",
  "title": "PWG Russian lexicographic portrait",
  "type": "object",
  "required": [
    "schema_version",
    "key1",
    "key2",
    "h",
    "iast",
    "pos",
    "diasystem",
    "labels",
    "senses"
  ],
  "properties": {
    "schema_version": {
      "const": "pwg_ru.lexicographic_portrait.v1"
    },
    "key1": { "type": "string", "minLength": 1 },
    "key2": { "type": "string" },
    "h": { "type": "string" },
    "iast": { "type": "string" },
    "pos": { "type": "array", "items": { "type": "string" } },
    "diasystem": { "type": "array", "items": { "type": "string" } },
    "labels": { "type": "array", "items": { "type": "string" } },
    "senses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sense" }
    },
    "corpus_synonyms": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/corpus_synonyms" }
      ]
    }
  },
  "$defs": {
    "sense": {
      "type": "object",
      "required": [
        "n",
        "sub",
        "equivalents_de",
        "gloss_de",
        "equivalence_type",
        "grammar",
        "ab_labels",
        "diasystem",
        "citations",
        "citations_resolved",
        "strata",
        "examples_sa"
      ],
      "properties": {
        "n": { "type": "string" },
        "sub": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "equivalents_de": { "type": "array", "items": { "type": "string" } },
        "gloss_de": { "type": "string" },
        "equivalence_type": {
          "enum": ["equivalent", "explanatory", "none"]
        },
        "grammar": { "type": "array", "items": { "type": "string" } },
        "ab_labels": { "type": "array", "items": { "type": "string" } },
        "diasystem": { "type": "array", "items": { "type": "string" } },
        "citations": { "type": "array", "items": { "type": "string" } },
        "citations_resolved": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [{ "type": "string" }, { "type": "null" }]
          }
        },
        "strata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "examples_sa": { "type": "array", "items": { "type": "string" } }
      }
    },
    "corpus_synonyms": {
      "type": "object",
      "required": ["n", "by_stratum", "candidates"],
      "properties": {
        "n": { "type": "integer", "minimum": 0 },
        "by_stratum": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "candidates": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
