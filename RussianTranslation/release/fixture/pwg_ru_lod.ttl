<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/rakz/tr/rakz_x7e__x7e_h0_x5f_zz_x5f_pw/PW_x20_1_xe3__x80__x89_> a ontolex:LexicalSense ;
  skos:definition "<hom>1.</hom> √{#rakz#}¦ {#ra/kzati, ˚te#} ({#rakzye#} <ab>Fut.</ab> <ls n=\"Chr.\">89,28</ls>)\n<div n=\"1\">— 1〉 {%стеречь, нести стражу, сохранять, защищать, охранять%} (в т.ч. скот), {%оберегать, блюсти, щадить, содержать, спасать, servare, — от%} (<ab>Abl.</ab>), {%хранить; тщательно следить за%} (<ab>Acc.</ab>, в виде исключения <ab>Loc.</ab>), {%соблюдать%} (закон <ab>u. s. w.</ab>). Страну —, царство {%защищать,%} т.е. <ab>v. a.</ab> {%управлять%}. {#ra/kzamARa#} <ls>AV. 13,4,70</ls>. с пассивным <ab>Bed.</ab> или ошибочно вместо {#rakzya/mARa#} {#rakzita/#} {%охраняемый%} <ab>u. s. w.</ab> {#rakzitam#} <lex>Adv.</lex> {%надёжно сохранённый%}."@ru ;
  pwglex:sourceGloss "<hom>1.</hom> √{#rakz#}¦ {#ra/kzati, ˚te#} ({#rakzye#} <ab>Fut.</ab> <ls n=\"Chr.\">89,28</ls>)\n<div n=\"1\">— 1〉 {%bewachen, Wache halten, bewahren, beschützen, hüten%} (auch das Vieh), {%behüten, in Acht nehmen, schonen, erhalten, erretten, servare, — vor%} (<ab>Abl.</ab>), {%verwahren; sorgfältig achten auf%} (<ab>Acc.</ab>, ganz ausnahmsweise <ab>Loc.</ab>), {%beobachten%} (ein Gesetz <ab>u. s. w.</ab>). Das Land —, das Reich {%beschützen,%} so <ab>v. a.</ab> {%regieren%}. {#ra/kzamARa#} <ls>AV. 13,4,70</ls>. mit passiver <ab>Bed.</ab> oder fehlerhaft für {#rakzya/mARa#} {#rakzita/#} {%bewacht%} <ab>u. s. w.</ab> {#rakzitam#} <lex>Adv.</lex> {%wohl verwahrt%}."@de ;
  pwglex:senseTag "PW 1〉" ;
  pwglex:homonym "h0" ;
  pwglex:equivalenceType "equivalent" ;
