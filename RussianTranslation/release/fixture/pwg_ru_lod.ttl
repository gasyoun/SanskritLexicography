<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/rakz/tr/rakz_x7e__x7e_h0_x5f_15_x5f_sam/sam_x20__x28_1_x29_> a ontolex:LexicalSense ;
  skos:definition "<div n=\"p\">— {#sam#} {%стеречь, сохранять, защищать, охранять, оберегать, содержать, спасать, servare%}: {#saMrakzato munigaRAnniGnato rAkzasAnmama#}\n<ls>R. 3,10,25.</ls> <ls n=\"R.\">7,108,27.</ls> <ls>Spr. 1828.</ls> <ls>Verz. d. Oxf. H. 257,a, N. 3.</ls> {#saMrakzyamARo rAjYA#}\n<ls>M. 7,136.</ls>\n<ls>MBH. 7,230.</ls> <ls n=\"MBH. 7,\">6059.</ls>\n<ls>R. 5,19,33.</ls>\n<ls>KATHĀS. 20,87.</ls>\n<ls>RĀJA-TAR. 3,39.</ls> {#saMrakzita#}\n<ls>HARIV. 9072.</ls>\n<ls>MṚCCH. 105,13. 110,15.</ls>\n<ls>RAGH. 4,35.</ls> <ls n=\"RAGH.\">13,65.</ls>\n<ls>KATHĀS. 9,80.</ls> {#saMrakzetsarvataScEnaM pitA putramivOrasam#}\n<ls>M. 7,135.</ls> {#pitrA saMrakzitaM SakrAt#}\n<ls>BHAṬṬ. 8,8.</ls> {#kedArAn — mfgavarAhAdiByaH saMrakzamARamaNgiraHpravarasutam#}\n<ls>BHĀG. P. 5,9,14.</ls> {#prAREH saMrakzitEH sarvaM yato Bavati rakzitam#}\n<ls>Spr. 3163.</ls> {#kawakaM saMrakzya#}\n<ls>RĀJA-TAR. 5,218.</ls> {#anidra eva zaqrAtraM sa saMrakzanmuneH kratum#}\n<ls>R. GORR. 1,33,6.</ls> {#maDuvanaM saMrakza tvam#}\n<ls n=\"R. GORR.\">5,63,27.</ls> {#DarmaM saMrakzate daRqastaTEvArTaM janADipa . kAmaM saMrakzate daRqaH#}\n<ls>MBH. 12,426.</ls> {#vfttaM yatnena saMrakzet#}\n<ls>Spr. 5030.</ls> {#saMrakzenmantrabIjam#}\n<ls>KĀM. NĪTIS. 11,53.</ls> {#mantraM saMrakzet#}\n<ls n=\"KĀM. NĪTIS.\">64.</ls> {#daMpatyoH saMrakzatorgOravam#} {%сохранять%}\n<ls>Spr. 530.</ls> {#AtmanaSca parezAM ca vfttiM saMrakza#} {%обеспечь%}\n<ls>MBH. 13,3080.</ls> {%хранить, беречь%}: {#taddAnavaSarIraM te saMrakzya sTApitaM mayA#}\n<ls>KATHĀS. 45,50.</ls>"@ru ;
  pwglex:sourceGloss "<div n=\"p\">— {#sam#} {%bewachen, bewahren, beschützen, hüten, behüten, erhalten, erretten, servare%}: {#saMrakzato munigaRAnniGnato rAkzasAnmama#}\n<ls>R. 3,10,25.</ls> <ls n=\"R.\">7,108,27.</ls> <ls>Spr. 1828.</ls> <ls>Verz. d. Oxf. H. 257,a, N. 3.</ls> {#saMrakzyamARo rAjYA#}\n<ls>M. 7,136.</ls>\n<ls>MBH. 7,230.</ls> <ls n=\"MBH. 7,\">6059.</ls>\n<ls>R. 5,19,33.</ls>\n<ls>KATHĀS. 20,87.</ls>\n<ls>RĀJA-TAR. 3,39.</ls> {#saMrakzita#}\n<ls>HARIV. 9072.</ls>\n<ls>MṚCCH. 105,13. 110,15.</ls>\n<ls>RAGH. 4,35.</ls> <ls n=\"RAGH.\">13,65.</ls>\n<ls>KATHĀS. 9,80.</ls> {#saMrakzetsarvataScEnaM pitA putramivOrasam#}\n<ls>M. 7,135.</ls> {#pitrA saMrakzitaM SakrAt#}\n<ls>BHAṬṬ. 8,8.</ls> {#kedArAn — mfgavarAhAdiByaH saMrakzamARamaNgiraHpravarasutam#}\n<ls>BHĀG. P. 5,9,14.</ls> {#prAREH saMrakzitEH sarvaM yato Bavati rakzitam#}\n<ls>Spr. 3163.</ls> {#kawakaM saMrakzya#}\n<ls>RĀJA-TAR. 5,218.</ls> {#anidra eva zaqrAtraM sa saMrakzanmuneH kratum#}\n<ls>R. GORR. 1,33,6.</ls> {#maDuvanaM saMrakza tvam#}\n<ls n=\"R. GORR.\">5,63,27.</ls> {#DarmaM saMrakzate daRqastaTEvArTaM janADipa . kAmaM saMrakzate daRqaH#}\n<ls>MBH. 12,426.</ls> {#vfttaM yatnena saMrakzet#}\n<ls>Spr. 5030.</ls> {#saMrakzenmantrabIjam#}\n<ls>KĀM. NĪTIS. 11,53.</ls> {#mantraM saMrakzet#}\n<ls n=\"KĀM. NĪTIS.\">64.</ls> {#daMpatyoH saMrakzatorgOravam#} {%bewahren%}\n<ls>Spr. 530.</ls> {#AtmanaSca parezAM ca vfttiM saMrakza#} {%sichre%}\n<ls>MBH. 13,3080.</ls> {%aufbewahren, verwahren%}: {#taddAnavaSarIraM te saMrakzya sTApitaM mayA#}\n<ls>KATHĀS. 45,50.</ls>"@de ;
  pwglex:senseTag "sam (1)" ;
  pwglex:homonym "h0" ;
  pwglex:equivalenceType "equivalent" ;
  pwglex:sourceType "attested" ;
  pwglex:differentia "Широкий семантический ряд: «bewachen» — стеречь (надзор), «bewahren» / «verwahren» / «aufbewahren» — сохранять / хранить (сберегать от утраты), «beschützen» / «behüten» — защищать / оберегать (ограждение от угрозы), «hüten» — охранять (пастушеский/воинский надзор), «erhalten» — содержать (поддержание целостности), «erretten» — спасать (избавление от беды), servare (латинский эквивалент). Кардинальность семи членов сохранена."@ru ;
  pwglex:evidenceGrade gr:machine-preview ;
