<https://w3id.org/sanskrit-lexicon/pwg-ru/entry/rakz-2> a ontolex:LexicalEntry ;
  rdfs:label "rakṣ"@sa-Latn ;
  dct:isPartOf <https://w3id.org/sanskrit-lexicon/pwg-ru/lexicon/pwg-ru> ;
  ontolex:canonicalForm <https://w3id.org/sanskrit-lexicon/pwg-ru/lemma/rakz> ;
