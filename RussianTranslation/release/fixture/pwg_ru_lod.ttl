<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/aMSa-4/dict/kna/1> a ontolex:LexicalSense ;
  skos:definition "अंश\t/aṃśa/\t/aMza/\t/анша/\taṅśa m. часть, доля; S. 2, 26 наслѣдственная доля. — [ср. подъ 1. aś, aṅś].\tс. 193"@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "kna" .
<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/aMSa-4/dict/fri/2> a ontolex:LexicalSense ;
  skos:definition "aṃśa m.; доля, удел, часть"@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "fri" .

