<https://w3id.org/sanskrit-lexicon/pwg-ru/entry/a-3> a ontolex:LexicalEntry ;
  rdfs:label "a"@sa-Latn ;
  dct:isPartOf <https://w3id.org/sanskrit-lexicon/pwg-ru/lexicon/pwg-ru> ;
  ontolex:canonicalForm <https://w3id.org/sanskrit-lexicon/pwg-ru/lemma/a> ;
  ontolex:sense <https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/koch/1>, <https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/koch/2>, <https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/kna/3>, <https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/fri/4>, <https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/fri/5>, <https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/smirnov/6> .
<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/koch/1> a ontolex:LexicalSense ;
  skos:definition "अ° /a-/ (перед гласными अन्°) pref. без-, не-"@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "koch" .
<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/koch/2> a ontolex:LexicalSense ;
  skos:definition "अ /a/ первая буква алфавита деванагари- см. देवनागरी"@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "koch" .
<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/kna/3> a ontolex:LexicalSense ;
  skos:definition "अ॰\t/a-/\t\t/а-/\ta- передъ согл., an- передъ гласн.: отрицательная частица не-, без- [греч. ἀ-, ἀν-, лат. in-, герм. un-].\tс. 193"@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "kna" .
<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/fri/4> a ontolex:LexicalSense ;
  skos:definition "I a- pron., cf. a-tas, a-tra &c.;"@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "fri" .
<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/fri/5> a ontolex:LexicalSense ;
  skos:definition "II a- augment;"@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "fri" .
<https://w3id.org/sanskrit-lexicon/pwg-ru/sense/entry/a-3/dict/smirnov/6> a ontolex:LexicalSense ;
  skos:definition "(II-2) —X, 33; первая буква алфавита; употребляется как 1) междометие; 2) корень местоимения 1-го лица (aham) и 2-го лица (tvam); 3) перед согласным в начале слова (перед гласным an отрицательная частица не, без). Таким образом, понятие, выраженное словом, отрицается, напр., akarman (II, 47) неделающий, adeśakale в недолжном месте и времени (XVII, 22); 4) символ Вишну."@ru ;
  pwglex:evidenceGrade gr:dict-attested ;
  dct:source "smirnov" .

<https://w3id.org/sanskrit-lexicon/pwg-ru/entry/aMSa-4> a ontolex:LexicalEntry ;
