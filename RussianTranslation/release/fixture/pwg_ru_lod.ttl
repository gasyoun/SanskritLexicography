  skos:definition "<div n=\"p\">— {#prati#}\n<div n=\"1\"> 1) {%беречь, защищать%}: {#yadi SUrastaTA kzeme#} ({#kzemaM#} <ls>ed. Bomb.</ls>) {#pratirakzedyaTA Baye#}\n<ls>MBH. 12,3596.</ls> {#viSvA\\ ASA\\H prati^ rakza\\ntyeke^#}\n<ls>AV. 10,8,36.</ls> {#satyAM#} (так <ls>ed. Bomb.</ls>) {#pratijYAM tAM pArTena pratirakzatA#} {%верно соблюдая%}\n<ls>MBH. 8,3542.</ls>"@ru ;
  pwglex:sourceGloss "<div n=\"p\">— {#prati#}\n<div n=\"1\"> 1) {%behüten, beschützen%}: {#yadi SUrastaTA kzeme#} ({#kzemaM#} <ls>ed. Bomb.</ls>) {#pratirakzedyaTA Baye#}\n<ls>MBH. 12,3596.</ls> {#viSvA\\ ASA\\H prati^ rakza\\ntyeke^#}\n<ls>AV. 10,8,36.</ls> {#satyAM#} (so die <ls>ed. Bomb.</ls>) {#pratijYAM tAM pArTena pratirakzatA#} {%treu haltend%}\n<ls>MBH. 8,3542.</ls>"@de ;
