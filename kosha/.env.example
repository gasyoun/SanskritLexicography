# kosha Configuration

# Database
DATABASE_PATH=./unified_dict.db

# Caching
CACHE_SIZE=5000
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO

# Cologne scan archive
COLOGNE_SCAN_BASE=https://cologne.archive.org/dictionaries

# GitHub webhook (for real-time sync)
GITHUB_WEBHOOK_SECRET=your-secret-here

# API settings
API_TITLE=kosha
API_DESCRIPTION=Fast Sanskrit Dictionary Lookup
API_VERSION=1.0.0

# CORS (for GitHub Pages + external access)
CORS_ORIGINS=["https://gasyoun.github.io","https://samskrtam.ru","http://localhost:3000"]
